<?xml version="1.0" ?>
<sdf version="1.6">
  <model name="roarm_quad">
  <static>false</static>
    <!-- ========================================== -->
    <!--          1. 无人机主体 (Drone Body)         -->
    <!-- ========================================== -->
    <link name="base_link">
      <pose>0 0 1.4 0 0 0</pose> <!-- 整体模型的初始起飞高度 -->
      <inertial>
        <!-- 💡 1. 无人机物理质心位置参数：修改前三项 [x y z] 调整质心物理偏置 (当前设为中心 0 0 0) -->
        <pose>0 0 0 0 0 0</pose>
        <mass>3.6</mass> <!-- 无人机机身 3.6kg -->
        <inertia>
          <!-- 550轴距/3.6kg 估算的转动惯量 -->
          <ixx>0.045</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.045</iyy>
          <iyz>0</iyz>
          <izz>0.071</izz>
        </inertia>
      </inertial>
      
      <collision name="base_link_collision">
        <!-- 💡 调整此处 pose 使碰撞体 STL 与视觉网格完全重合并对齐 -->
        <pose>0 0 0 3.14159265 0 0</pose>
        <geometry>
          <!-- 💡 恢复使用无人机 STL 碰撞网格，彻底解决起落架穿地问题，同时实现精细化碰撞检测 -->
          <mesh>
            <scale>0.001 0.001 0.001</scale> <!-- 极其重要！碰撞体必须等比缩小1000倍，否则产生550米超大实体压入地面会瞬间爆炸 -->
            <uri>model://roarm_quad/meshes/drone_body.STL</uri>
          </mesh>
        </geometry>
         <surface>
          <contact>
            <collide_bitmask>0x01</collide_bitmask>
          </contact>
        </surface>
      </collision>
      
      <visual name="base_link_visual">
        <!-- 💡 2. 无人机 3D 机身网格微调参数：
             - 前三项 [x y z]：微调 3D 视觉模型与物理中心的坐标偏差。
             - 后三项 [r p y]：当前设为 [3.14159265 0 0] 使机身保持正向朝上。 -->
        <pose>0 0 0 3.14159265 0 0</pose> 
        <geometry>
          <mesh>
            <scale>0.001 0.001 0.001</scale> <!-- 毫米STL在此等比缩小为米 -->
            <uri>model://roarm_quad/meshes/drone_body.STL</uri>
          </mesh>
        </geometry>
      </visual>
    </link>

    <!-- ========================================== -->
    <!--         2. 机械臂级联导入 (RoArm Arm)        -->
    <!-- ========================================== -->
    <!-- 💡 机械臂总质量已完美等比放大至 0.85kg 目标重量 -->
    <link name="arm_base_link">
      <!-- 💡 3. 机械臂安装与旋转参数：
           - 前三项 [x y z]：修改 z (当前-0.06) 可以调整机械臂在无人机下方挂载的高度（贴合电池仓底面），正面看，向前，向右，向上。
           - 后三项 [r p y]：第一项 Roll 设为 3.14159265，已实现机械臂整体一键翻转朝下挂载。 -->
      <pose relative_to="base_link">0.006 0.037 0.07 3.14159265 0 0</pose> 
      <inertial>
        <pose>0.00373847392098165 -1.52445893424664E-10 0.0264265327292804 0 0 0</pose>
        <mass>0.436540</mass> <!-- 官方原始: 0.326393kg -> 1.337倍放大 -->
        <inertia>
          <ixx>0.000299864</ixx>
          <ixy>-2.63178E-13</ixy>
          <ixz>-4.00204E-05</ixz>
          <iyy>0.000383341</iyy>
          <iyz>-4.15904E-13</iyz>
          <izz>0.000468057</izz>
        </inertia>
      </inertial>
      <visual name="arm_base_link_visual">
        <geometry>
          <mesh>
            <uri>model://roarm_quad/meshes/base_link.STL</uri>
          </mesh>
        </geometry>
      </visual>
      <collision name="arm_base_link_collision">
        <geometry>
          <mesh>
            <uri>model://roarm_quad/meshes/base_link.STL</uri>
          </mesh>
        </geometry>
         <surface>
          <contact>
            <collide_bitmask>0x02</collide_bitmask>
          </contact>
        </surface>
      </collision>
    </link>

    <!-- 刚性连接无人机 base_link 和 机械臂 arm_base_link -->
    <joint name="drone_to_arm_joint" type="fixed">
      <parent>base_link</parent>
      <child>arm_base_link</child>
    </joint>

    <!-- 关节 1 -->
    <link name="link1">
      <pose relative_to="arm_base_link">0.01 0 0.123059 0 0 0</pose>
      <inertial>
        <pose>-3.11559626639357E-12 9.70240468164796E-06 -0.0146667419724465 0 0 0</pose>
        <mass>0.124236</mass> <!-- 官方原始: 0.092889kg -> 1.337倍放大 -->
        <inertia>
          <ixx>8.14800E-05</ixx>
          <ixy>-3.73431E-18</ixy>
          <ixz>5.68212E-15</ixz>
          <iyy>3.39040E-05</iyy>
          <iyz>2.89485E-08</iyz>
          <izz>6.52752E-05</izz>
        </inertia>
      </inertial>
      <visual name="link1_visual"><geometry><mesh><uri>model://roarm_quad/meshes/link1.STL</uri></mesh></geometry></visual>
      <collision name="link1_collision"><geometry><mesh><uri>model://roarm_quad/meshes/link1.STL</uri></mesh></geometry>
      
         <surface>
          <contact>
            <collide_bitmask>0x02</collide_bitmask>
          </contact>
        </surface>
      </collision>
    </link>
    <joint name="base_link_to_link1" type="revolute">
      <parent>arm_base_link</parent>
      <child>link1</child>
      <axis>
        <xyz>0 0 -1</xyz>
        <limit><lower>-3.1416</lower><upper>3.1416</upper><effort>10</effort><velocity>5</velocity></limit>
        <!-- 💡 增加关节阻尼与摩擦，模拟真实减速电机的物理阻力，阻碍自由晃动 -->
        <dynamics>
          <damping>0.1</damping>
          <friction>0.1</friction>
        </dynamics>
      </axis>
      <!-- 💡 开启隐式弹簧阻尼器，彻底防止限位撞击时的数值发散爆炸 -->
      <physics>
        <ode>
          <implicit_spring_damper>true</implicit_spring_damper>
        </ode>
      </physics>
    </joint>

    <!-- 关节 2 -->
    <link name="link2">
      <pose relative_to="link1">0 0 0 -1.57079632679 -3.1415926535 0</pose>
      <inertial>
        <pose>0.122021157535333 6.61338425981053E-05 -9.50311342843365E-05 0 0 0</pose>
        <mass>0.119813</mass> <!-- 官方原始: 0.089582kg -> 1.337倍放大 -->
        <inertia>
          <ixx>3.51344E-05</ixx>
          <ixy>-3.41515E-06</ixy>
          <ixz>-5.21931E-09</ixz>
          <iyy>0.000468608</iyy>
          <iyz>-9.12681E-09</iyz>
          <izz>0.000445453</izz>
        </inertia>
      </inertial>
      <visual name="link2_visual"><geometry><mesh><uri>model://roarm_quad/meshes/link2.STL</uri></mesh></geometry></visual>
      <collision name="link2_collision"><geometry><mesh><uri>model://roarm_quad/meshes/link2.STL</uri></mesh></geometry>
         <surface>
          <contact>
            <collide_bitmask>0x02</collide_bitmask>
          </contact>
        </surface>
      
      </collision>
    </link>
    <joint name="link1_to_link2" type="revolute">
      <parent>link1</parent>
      <child>link2</child>
      <axis>
        <xyz>0 0 -1</xyz>
        <limit><lower>-1.5708</lower><upper>1.5708</upper><effort>10</effort><velocity>5</velocity></limit>
        <!-- 💡 增加关节阻尼与摩擦 -->
        <dynamics>
          <damping>0.2</damping>
          <friction>0.2</friction>
        </dynamics>
      </axis>
      <!-- 💡 开启隐式弹簧阻尼器 -->
      <physics>
        <ode>
          <implicit_spring_damper>true</implicit_spring_damper>
        </ode>
      </physics>
    </joint>

    <!-- 关节 3 -->
    <link name="link3">
      <pose relative_to="link2">0.236815 0.030002 0 0 -1.57079632679 -1.57079632679</pose>
      <inertial>
        <pose>-0.00076280945740961 -0.114419656440929 -0.000177274968057332 0 0 0</pose>
        <mass>0.164521</mass> <!-- 官方原始: 0.123009kg -> 1.337倍放大 -->
        <inertia>
          <ixx>0.000139246</ixx>
          <ixy>1.42365E-07</ixy>
          <ixz>2.07208E-07</ixz>
          <iyy>1.95748E-05</iyy>
          <iyz>-2.19819E-07</iyz>
          <izz>0.000139109</izz>
        </inertia>
      </inertial>
      <visual name="link3_visual"><geometry><mesh><uri>model://roarm_quad/meshes/link3.STL</uri></mesh></geometry></visual>
      <collision name="link3_collision"><geometry><mesh><uri>model://roarm_quad/meshes/link3.STL</uri></mesh></geometry>
         <surface>
          <contact>
            <collide_bitmask>0x02</collide_bitmask>
          </contact>
        </surface>
      
      </collision>
    </link>
    <joint name="link2_to_link3" type="revolute">
      <parent>link2</parent>
      <child>link3</child>
      <axis>
        <!-- 💡 修复：由于 link3 的 pose 相对 link2 进行了大角度旋转，其 local Z轴 已完全偏转。 -->
        <!-- 经旋转矩阵推算，平行于大臂的俯仰轴现在对应 link3 局部坐标系的 X 轴，因此必须修改为 [1 0 0]！ -->
        <xyz>1 0 0</xyz>
        <limit><lower>-1</lower><upper>3.1416</upper><effort>10</effort><velocity>5</velocity></limit>
        <!-- 💡 增加关节阻尼与摩擦 -->
        <dynamics>
          <damping>0.1</damping>
          <friction>0.1</friction>
        </dynamics>
      </axis>
      <!-- 💡 开启隐式弹簧阻尼器 -->
      <physics>
        <ode>
          <implicit_spring_damper>true</implicit_spring_damper>
        </ode>
      </physics>
    </joint>

    <!-- 夹爪 -->
    <link name="gripper_link">
      <pose relative_to="link3">0.002906 -0.21599 -0.000667 -1.5708 0 -1.5708</pose>
      <inertial>
        <pose>0.0288857415118809 -0.000776842039187049 -0.000779764534254559 0 0 0</pose>
        <mass>0.004891</mass> <!-- 官方原始: 0.003657kg -> 1.337倍放大 -->
        <inertia>
          <ixx>1.54000E-06</ixx>
          <ixy>1.75543E-07</ixy>
          <ixz>-3.23607E-13</ixz>
          <iyy>3.11670E-06</iyy>
          <iyz>5.53608E-13</iyz>
          <izz>1.96850E-06</izz>
        </inertia>
      </inertial>
      <visual name="gripper_link_visual"><geometry><mesh><uri>model://roarm_quad/meshes/gripper_link.STL</uri></mesh></geometry></visual>
      <collision name="gripper_link_collision"><geometry><mesh><uri>model://roarm_quad/meshes/gripper_link.STL</uri></mesh></geometry></collision>
    </link>
    <joint name="link3_to_gripper_link" type="revolute">
      <parent>link3</parent>
      <child>gripper_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>0</lower><upper>1.5</upper><effort>5</effort><velocity>5</velocity></limit>
        <!-- 💡 增加关节阻尼与摩擦 -->
        <dynamics>
          <damping>0.1</damping>
          <friction>0.1</friction>
        </dynamics>
      </axis>
      <!-- 💡 开启隐式弹簧阻尼器 -->
      <physics>
        <ode>
          <implicit_spring_damper>true</implicit_spring_damper>
        </ode>
      </physics>
    </joint>

    <!-- TCP 末端点 (无物理网格，仅用于 ROS2 运动学求解) -->
    <!-- 为 Dummy Link 补全极微小但安全的物理质量与转动惯量，防止物理引擎由于零解产生数学溢出（NaN）导致模型解体 -->
    <link name="hand_tcp">
      <pose relative_to="link3">0.002 -0.2802 0 -1.5708 0 -1.5708</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.01</mass> <!-- 10克微小质量 -->
        <inertia>
          <ixx>1e-08</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>1e-08</iyy><iyz>0</iyz>
          <izz>1e-08</izz>
        </inertia>
      </inertial>
    </link>
    <joint name="link3_to_hand_tcp" type="fixed">
      <parent>link3</parent>
      <child>hand_tcp</child>
    </joint>


    <!-- ========================================== -->
    <!--          3. 四个旋翼 (4 Rotors)             -->
    <!-- ========================================== -->
    <!-- 💡 螺旋桨高低参数调校：微调下面 4 个 link 里的第 3 项 z（当前 0.08m），即可将螺旋桨移动到电机轴头上 -->

    <!-- Rotor 0 (右前 FR, CCW) -->
    <link name="rotor_0">
      <!-- 💡 4. 螺旋桨 0 安装与高低参数 -->
      <pose relative_to="base_link">0.182 -0.15 0.1125 0 0 0</pose>
      <inertial><pose>0 0 0 0 0 0</pose><mass>0.005</mass><inertia><ixx>9.75e-07</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000273</iyy><iyz>0</iyz><izz>0.000274</izz></inertia></inertial>
      <visual name="rotor_0_visual"><geometry><mesh><scale>1 1 1</scale><uri>model://roarm_quad/meshes/iris_prop_ccw.dae</uri></mesh></geometry></visual>
    </link>
    <joint name="rotor_0_joint" type="revolute">
      <parent>base_link</parent><child>rotor_0</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
        <!-- 💡 增加微量阻尼保持电机旋转轴物理计算稳定，切勿设得过大（如超过0.01），否则会因阻力消耗电机输出拉力 -->
        <dynamics>
          <damping>0.001</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- Rotor 1 (左后 BL, CCW) -->
    <link name="rotor_1">
      <!-- 💡 4. 螺旋桨 1 安装与高低参数 -->
      <pose relative_to="base_link">-0.197 0.228 0.1125 0 0 0</pose>
      <inertial><pose>0 0 0 0 0 0</pose><mass>0.005</mass><inertia><ixx>9.75e-07</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000273</iyy><iyz>0</iyz><izz>0.000274</izz></inertia></inertial>
      <visual name="rotor_1_visual"><geometry><mesh><scale>1 1 1</scale><uri>model://roarm_quad/meshes/iris_prop_ccw.dae</uri></mesh></geometry></visual>
    </link>
    <joint name="rotor_1_joint" type="revolute">
      <parent>base_link</parent><child>rotor_1</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
        <!-- 💡 增加微量阻尼 -->
        <dynamics>
          <damping>0.001</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- Rotor 2 (左前 FL, CW) -->
    <link name="rotor_2">
      <!-- 💡 4. 螺旋桨 2 安装与高低参数 -->
      <pose relative_to="base_link">0.181 0.229 0.1125 0 0 0</pose>
      <inertial><pose>0 0 0 0 0 0</pose><mass>0.005</mass><inertia><ixx>9.75e-07</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000273</iyy><iyz>0</iyz><izz>0.000274</izz></inertia></inertial>
      <visual name="rotor_2_visual"><geometry><mesh><scale>1 1 1</scale><uri>model://roarm_quad/meshes/iris_prop_cw.dae</uri></mesh></geometry></visual>
    </link>
    <joint name="rotor_2_joint" type="revolute">
      <parent>base_link</parent><child>rotor_2</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
        <!-- 💡 增加微量阻尼 -->
        <dynamics>
          <damping>0.001</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- Rotor 3 (右后 BR, CW) -->
    <link name="rotor_3">
      <!-- 💡 4. 螺旋桨 3 安装与高低参数 -->
      <pose relative_to="base_link">-0.2 -0.1515 0.1125 0 0 0</pose>
      <inertial><pose>0 0 0 0 0 0</pose><mass>0.005</mass><inertia><ixx>9.75e-07</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000273</iyy><iyz>0</iyz><izz>0.000274</izz></inertia></inertial>
      <visual name="rotor_3_visual"><geometry><mesh><scale>1 1 1</scale><uri>model://roarm_quad/meshes/iris_prop_cw.dae</uri></mesh></geometry></visual>
    </link>
    <joint name="rotor_3_joint" type="revolute">
      <parent>base_link</parent><child>rotor_3</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
        <!-- 💡 增加微量阻尼 -->
        <dynamics>
          <damping>0.001</damping>
        </dynamics>
      </axis>
    </joint>


    <!-- ========================================== -->
    <!--         4. PX4 电机与通信控制仿真插件        -->
    <!-- ========================================== -->
    <!-- 💡 注意：为了应对 4.45kg 总载荷，我们将 <motorConstant> 调整为了 2.2e-05 -->

    <!-- Motor 0 (FR) -->
    <plugin name='front_right_motor_model' filename='libgazebo_motor_model.so'>
      <robotNamespace/>
      <jointName>rotor_0_joint</jointName>
      <linkName>rotor_0</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1100</maxRotVelocity>
      <motorConstant>2.2e-05</motorConstant>
      <momentConstant>0.06</momentConstant>
      <commandSubTopic>/gazebo/command/motor_speed</commandSubTopic>
      <motorNumber>0</motorNumber>
      <rotorDragCoefficient>0.000175</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <motorSpeedPubTopic>/motor_speed/0</motorSpeedPubTopic>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>

    <!-- Motor 1 (BL) -->
    <plugin name='back_left_motor_model' filename='libgazebo_motor_model.so'>
      <robotNamespace/>
      <jointName>rotor_1_joint</jointName>
      <linkName>rotor_1</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1100</maxRotVelocity>
      <motorConstant>2.2e-05</motorConstant>
      <momentConstant>0.06</momentConstant>
      <commandSubTopic>/gazebo/command/motor_speed</commandSubTopic>
      <motorNumber>1</motorNumber>
      <rotorDragCoefficient>0.000175</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <motorSpeedPubTopic>/motor_speed/1</motorSpeedPubTopic>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>

    <!-- Motor 2 (FL) -->
    <plugin name='front_left_motor_model' filename='libgazebo_motor_model.so'>
      <robotNamespace/>
      <jointName>rotor_2_joint</jointName>
      <linkName>rotor_2</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1100</maxRotVelocity>
      <motorConstant>2.2e-05</motorConstant>
      <momentConstant>0.06</momentConstant>
      <commandSubTopic>/gazebo/command/motor_speed</commandSubTopic>
      <motorNumber>2</motorNumber>
      <rotorDragCoefficient>0.000175</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <motorSpeedPubTopic>/motor_speed/2</motorSpeedPubTopic>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>

    <!-- Motor 3 (BR) -->
    <plugin name='back_right_motor_model' filename='libgazebo_motor_model.so'>
      <robotNamespace/>
      <jointName>rotor_3_joint</jointName>
      <linkName>rotor_3</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1100</maxRotVelocity>
      <motorConstant>2.2e-05</motorConstant>
      <momentConstant>0.06</momentConstant>
      <commandSubTopic>/gazebo/command/motor_speed</commandSubTopic>
      <motorNumber>3</motorNumber>
      <rotorDragCoefficient>0.000175</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <motorSpeedPubTopic>/motor_speed/3</motorSpeedPubTopic>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>

    <!-- MAVLink 核心仿真器插件 (连接 Gazebo 和 PX4 SITL) -->
    <plugin name='mavlink_interface' filename='libgazebo_mavlink_interface.so'>
      <robotNamespace/>
      <imuSubTopic>/imu</imuSubTopic>
      <magSubTopic>/mag</magSubTopic>
      <baroSubTopic>/baro</baroSubTopic>
      <gpsSubTopic>/gps</gpsSubTopic>
      <mavlink_addr>INADDR_ANY</mavlink_addr>
      <mavlink_udp_port>14560</mavlink_udp_port>
      <mavlink_tcp_port>4560</mavlink_tcp_port>
      
      <serialEnabled>0</serialEnabled>
      <serialDevice>/dev/ttyACM0</serialDevice>
      <baudRate>921600</baudRate>
      <qgc_addr>INADDR_ANY</qgc_addr>
      <qgc_udp_port>14550</qgc_udp_port>
      <sdk_addr>INADDR_ANY</sdk_addr>
      <sdk_udp_port>14540</sdk_udp_port>
      <hil_mode>0</hil_mode>
      <hil_state_level>0</hil_state_level>
      <send_vision_estimation>0</send_vision_estimation>
      <send_odometry>1</send_odometry>
      <enable_lockstep>1</enable_lockstep>
      <use_tcp>1</use_tcp>
           
      <use_software_mavlink>1</use_software_mavlink>
      <motorSpeedCommandPubTopic>/gazebo/command/motor_speed</motorSpeedCommandPubTopic>
      <control_channels>
        <channel name='rotor0'>
          <input_index>0</input_index>
          <input_offset>0</input_offset>
          <input_scaling>1000</input_scaling>
          <zero_position_armed>100</zero_position_armed>
          <joint_control_type>velocity</joint_control_type>
        </channel>
        <channel name='rotor1'>
          <input_index>1</input_index>
          <input_offset>0</input_offset>
          <input_scaling>1000</input_scaling>
          <zero_position_armed>100</zero_position_armed>
          <joint_control_type>velocity</joint_control_type>
        </channel>
        <channel name='rotor2'>
          <input_index>2</input_index>
          <input_offset>0</input_offset>
          <input_scaling>1000</input_scaling>
          <zero_position_armed>100</zero_position_armed>
          <joint_control_type>velocity</joint_control_type>
        </channel>
        <channel name='rotor3'>
          <input_index>3</input_index>
          <input_offset>0</input_offset>
          <input_scaling>1000</input_scaling>
          <zero_position_armed>100</zero_position_armed>
          <joint_control_type>velocity</joint_control_type>
        </channel>
      </control_channels>
    </plugin>

    <!-- IMU 物理插件 -->
    <plugin name='rotors_gazebo_imu_plugin' filename='libgazebo_imu_plugin.so'>
      <robotNamespace/>
      <linkName>/imu_link</linkName>
      <imuTopic>/imu</imuTopic>
    </plugin>
    <link name='/imu_link'>
      <pose>0 0 0 0 0 0</pose>
      <inertial><pose>0 0 0 0 0 0</pose><mass>0.015</mass><inertia><ixx>1e-05</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1e-05</iyy><iyz>0</iyz><izz>1e-05</izz></inertia></inertial>
    </link>
    <joint name='/imu_joint' type='revolute'>
      <parent>base_link</parent><child>/imu_link</child>
      <axis><xyz>1 0 0</xyz><limit><lower>0</lower><upper>0</upper></limit></axis>
    </joint>
<!-- ========================================== -->
    <!--          5. 补全 PX4 必需的物理传感器插件     -->
    <!-- ========================================== -->

    <!-- 💡 5.1 增加 GPS 模块（物理 Link 导入与固定关节） -->
    <include>
      <uri>model://gps</uri>
      <pose>0.05 0 0.04 0 0 0</pose>
      <name>gps0</name>
    </include>
    <joint name='gps0_joint' type='fixed'>
      <child>gps0::link</child>
      <parent>base_link</parent>
    </joint>

    <!-- 💡 5.2 增加地磁计（磁力计/指南针）插件，解决 Compass 0 missing 报错 -->
    <plugin name='magnetometer_plugin' filename='libgazebo_magnetometer_plugin.so'>
      <robotNamespace/>
      <pubRate>100</pubRate>
      <noiseDensity>0.0004</noiseDensity>
      <randomWalk>6.4e-06</randomWalk>
      <biasCorrelationTime>600</biasCorrelationTime>
      <magTopic>/mag</magTopic>
    </plugin>

    <!-- 💡 5.3 增加气压计插件，解决 Barometer 0 missing 报错 -->
    <plugin name='barometer_plugin' filename='libgazebo_barometer_plugin.so'>
      <robotNamespace/>
      <pubRate>50</pubRate>
      <baroTopic>/baro</baroTopic>
      <baroDriftPaPerSec>0</baroDriftPaPerSec>
    </plugin>

    <!-- 💡 5.4 增加真值插件 -->
    <plugin name='groundtruth_plugin' filename='libgazebo_groundtruth_plugin.so'>
      <robotNamespace/>
    </plugin>
  </model>
</sdf>
